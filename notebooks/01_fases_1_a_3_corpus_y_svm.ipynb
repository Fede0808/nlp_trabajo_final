    "aggressive = re.sub(r'[^a-záéíóúñ0-9_ ]', ' ', after)\n",
    "print(\"After aggressive:\", repr(aggressive))\n",
    "final = re.sub(r'\\s+', ' ', aggressive).strip()\n",
    "print(\"Final:\", repr(final))"
